DB_NAME=raportk
DATABASE_URL=postgres://raportk_user:GANTI_DENGAN_PASSWORD_KUAT_ANDA@postgres:5432/raportk

# PostgreSQL Container Environment (used by docker-compose)
POSTGRES_USER=raportk_user
POSTGRES_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_ANDA
POSTGRES_DB=raportk

# Better Auth Configuration
BETTER_AUTH_SECRET=GANTI_DENGAN_SECRET_RANDOM_64_KARAKTER
